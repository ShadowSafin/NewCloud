# Database
DB_USER=clouduser
DB_PASSWORD=cloudpass
DB_NAME=cloudstorage

# Backend
NODE_ENV=development
BACKEND_PORT=4000
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-at-least-32-random-characters
MEDIA_TOKEN_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
STORAGE_ROOT=/app/data/storage
MAX_FILE_SIZE=1099511627776
BULL_BOARD_USERNAME=admin
BULL_BOARD_PASSWORD=replace-with-at-least-32-random-characters

# Frontend
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
