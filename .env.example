# NexxCloud production configuration template
# Recommended first run: bash setup.sh (Linux/macOS) or setup.bat (Windows).
# The setup script generates strong values for every REQUIRED_GENERATED field.

# Deployment
NODE_ENV=production
COMPOSE_PROJECT_NAME=nexxcloud
FRONTEND_PORT=3000
BACKEND_PORT=4000
FRONTEND_BIND_ADDRESS=0.0.0.0
BACKEND_BIND_ADDRESS=0.0.0.0
NEXXCLOUD_DATA_DIR=./data

# Database (REQUIRED_GENERATED: DB_PASSWORD)
DB_USER=nexxcloud
DB_PASSWORD=GENERATE_WITH_SETUP
DB_NAME=nexxcloud

# Authentication and signed media (REQUIRED_GENERATED)
JWT_SECRET=GENERATE_WITH_SETUP
JWT_REFRESH_SECRET=GENERATE_WITH_SETUP
MEDIA_TOKEN_SECRET=GENERATE_WITH_SETUP
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Queue administration (REQUIRED_GENERATED: BULL_BOARD_PASSWORD)
BULL_BOARD_USERNAME=admin
BULL_BOARD_PASSWORD=GENERATE_WITH_SETUP

# Browser/proxy access
FRONTEND_URL=http://localhost:3000
# Comma-separated exact additional public origins, for example:
# CORS_ORIGINS=https://cloud.example.com,https://files.example.com
CORS_ORIGINS=
TRUST_PROXY=loopback, linklocal, uniquelocal

# LAN discovery (automatically populated by setup/start scripts when detectable)
HOST_LAN_IP=
HOST_HOSTNAME=

# Storage and upload policy
MAX_FILE_SIZE=10995116277760
UPLOAD_CHUNK_SIZE=67108864
MAX_UPLOAD_CHUNK_SIZE=268435456
TRASH_RETENTION_DAYS=30
MAX_VERSIONS_PER_FILE=10
DEFAULT_STORAGE_QUOTA=10995116277760
CHUNK_UPLOAD_CONCURRENCY=3
MAX_FILES_PER_USER=100000
MAX_UPLOADS_PER_MINUTE=300
